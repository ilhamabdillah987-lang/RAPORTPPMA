{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Data santri termasuk nilai dan identitas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "noUrut": { "type": "number" },
        "semester": { "type": "string", "enum": ["GANJIL", "GENAP"] },
        "tahunPelajaran": { "type": "string" },
        "nomorInduk": { "type": "string" },
        "subjects": { "type": "array" },
        "behavior": { "type": "object" },
        "extracurriculars": { "type": "array" },
        "attendance": { "type": "object" },
        "identity": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "class"]
    },
    "Config": {
      "title": "Config",
      "description": "Pengaturan sistem atau kelas",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["value"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Koleksi data santri"
    },
    "/configs/{configId}": {
      "schema": "Config",
      "description": "Koleksi pengaturan (logo, wali kelas, dll)"
    }
  }
}
