{
  "version": 2,
  "installCommand": "rm -rf node_modules package-lock.json && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/status",
      "destination": "/api"
    },
    {
      "source": "/((?!api|status).*)",
      "destination": "/index.html"
    }
  ]
}
