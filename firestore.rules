rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validations ---
    function isValidStudent(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 256
          && data.class is string && data.class.size() <= 64
          && data.keys().hasAll(['id', 'name', 'class']);
    }

    function isValidConfig(data) {
      return data.value is string && data.value.size() <= 2000000; // Allow ~2MB for Base64 logo
    }

    // --- Collections ---

    match /students/{studentId} {
      allow read, write: if true;
    }

    match /configs/{configId} {
      allow read, write: if true;
    }
  }
}
